<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="16dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivProfile"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_profile_circle"
                android:contentDescription="profile"
                android:padding="7dp"
                android:src="@android:drawable/ic_menu_myplaces" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:contentDescription="menu"
                android:src="@android:drawable/ic_menu_sort_by_size" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1週間の感情変化"
                android:textColor="#F3AEB7"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSeeAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="See all"
                android:textColor="#F3AEB7"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="10dp">

            <com.example.poilog.MoodFlowView
                android:id="@+id/moodFlowView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#FFFFFF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="7">

                <TextView
                    android:id="@+id/tvDate1"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_date_circle"
                    android:gravity="center"
                    android:text="--/--"
                    android:textColor="#3A3F4C"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDate2"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_date_circle"
                    android:gravity="center"
                    android:text="--/--"
                    android:textColor="#3A3F4C"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDate3"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_date_circle"
                    android:gravity="center"
                    android:text="--/--"
                    android:textColor="#3A3F4C"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDate4"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_date_circle"
                    android:gravity="center"
                    android:text="--/--"
                    android:textColor="#3A3F4C"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDate5"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_date_circle"
                    android:gravity="center"
                    android:text="--/--"
                    android:textColor="#3A3F4C"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDate6"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_date_circle"
                    android:gravity="center"
                    android:text="--/--"
                    android:textColor="#3A3F4C"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDate7"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_date_circle"
                    android:gravity="center"
                    android:text="--/--"
                    android:textColor="#3A3F4C"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tvLog1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_box"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="--  記録なし"
                android:textColor="#444A5A"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvLog2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_box"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="--  記録なし"
                android:textColor="#444A5A"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvLog3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_box"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="--  記録なし"
                android:textColor="#444A5A"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvLog4"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_box"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="--  記録なし"
                android:textColor="#444A5A"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvLog5"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_box"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="--  記録なし"
                android:textColor="#444A5A"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvLog6"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_box"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="--  記録なし"
                android:textColor="#444A5A"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvLog7"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_box"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="--  記録なし"
                android:textColor="#444A5A"
                android:textSize="17sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_panel"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="5">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="🏠"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="📊"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="📅"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="🖊"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="👤"
                android:textSize="24sp" />
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnGoInput"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="90dp"
        android:background="@drawable/bg_fab_circle"
        android:contentDescription="go_input"
        android:src="@android:drawable/ic_menu_edit"
        android:tint="#FFFFFF" />

</FrameLayout>
