<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4FA"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_panel"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="poilog☾"
            android:textColor="#F2A6AF"
            android:textSize="56sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="26dp"
            android:contentDescription="welcome_image"
            android:src="@drawable/welcome_sleep" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="poilogへようこそ！"
            android:textColor="#2F4A80"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="睡眠×生理×心\nあたらしい生活を送るためのアプリ。"
            android:textColor="#5F6070"
            android:textSize="26sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="42dp"
            android:backgroundTint="#F3B0B6"
            android:text="はじめる"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="38sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
